{
  "manifest_version": 3,
  "name": "J.A.R.V.I.S Screen Reader",
  "version": "1.0.0",
  "description": "Extracts page text for J.A.R.V.I.S AI assistant",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
