# === J.A.R.V.I.S Configuration ===

# App
APP_NAME=J.A.R.V.I.S
APP_ENV=development
APP_PORT=8000
APP_LOCALE=ko

# LLM Tiers (cost optimization)
LLM_TIER_LIGHT=gpt-4.1-nano
LLM_TIER_MEDIUM=gpt-4.1-mini
LLM_TIER_HEAVY=claude-sonnet-4-20250514

# API Keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=

# Deepgram (STT)
DEEPGRAM_API_KEY=

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Database
DATABASE_URL=sqlite+aiosqlite:///./jarvis.db

# JWT
JWT_SECRET_KEY=jarvis-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
